# OpenSubtitles API - https://www.opensubtitles.com/en/api-docs
OPENSUBTITLES_API_KEY=your_api_key_here
OPENSUBTITLES_USER_AGENT=YourBotName v1.0

# YouTube Data API v3 — OAuth2 credentials from Google Cloud Console
# To get YOUTUBE_REFRESH_TOKEN: run scripts/get_youtube_token.py once
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# TikTok — value of the `sessionid` cookie from a logged-in browser session
TIKTOK_SESSION_ID=

# Instagram — value of the `sessionid` cookie from a logged-in browser session
INSTAGRAM_SESSION_ID=

# TMDB (optional — enables movie poster + director/cast in video)
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_api_key_here
TMDB_READ_TOKEN=your_read_access_token_here
