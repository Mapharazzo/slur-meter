# OpenSubtitles
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USER_AGENT=
OPENSUBTITLES_JWT=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=

# Optional movie metadata
TMDB_READ_TOKEN=
OMDB_API_KEY=

# Paid audio providers (unused unless explicitly enabled in config.yaml)
ELEVENLABS_API_KEY=
OPENROUTER_API_KEY=

# YouTube OAuth (generate the refresh token with scripts/get_youtube_token.py)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Social publishing sessions
TIKTOK_SESSION_ID=
INSTAGRAM_SESSION_ID=

# Operations API authentication and browser origins
ADMIN_API_TOKEN=
ALLOW_LOCAL_DEVELOPMENT_AUTH=false
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8001

# Retry and subtitle selection tuning
RETRY_DELAYS=1,3,8
SUBTITLE_COVERAGE_THRESHOLD=0.70
SUBTITLE_CANDIDATES_PER_CYCLE=3

# Durable data and artifact roots (relative paths resolve from the project root)
DATA_DIR=data
OUTPUT_DIR=output
RESULTS_DIR=results
