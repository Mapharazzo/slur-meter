# OpenSubtitles API - https://www.opensubtitles.com/en/api-docs
OPENSUBTITLES_API_KEY=your_api_key_here
OPENSUBTITLES_USER_AGENT=YourBotName v1.0

# YouTube Data API v3 (for auto-upload)
# GOOGLE_APPLICATION_CREDENTIALS=~/.config/gcloud/application_default_credentials.json

# TikTok session cookie (for headless upload via Playwright)
# COOKIE_SID=
# COOKIE_SESSION=

# TMDB (optional — enables movie poster + director/cast in video)
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_api_key_here
TMDB_READ_TOKEN=your_read_access_token_here
